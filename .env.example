# Evolution API Configuration
EVOLUTION_API_URL=https://evo.your-domain.com
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=your_instance_name

# Webhook server
WEBHOOK_PORT=3000
WEBHOOK_BASE_URL=https://your-bot-public-url.com

# Charlie Project API
CHARLIE_API_URL=https://charlie-back.cloud-station.io
CHARLIE_PROJECT_ID=your_project_id

# Authentication: use ONE of the two methods below
# Method 1: USER_TOKEN (for local testing)
# USER_TOKEN=your_user_token

# Method 2: API Key (for production / CloudStation)
CHARLIE_API_KEY=your_api_key
CHARLIE_CLIENT_ID=your_client_id

# Optional: specify an agent template for Charlie to use
CHARLIE_AGENT_TEMPLATE_ID=
